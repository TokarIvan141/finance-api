generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  income
  expense
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  name         String
  createdAt    DateTime      @default(now()) @map("created_at")

  categories   Category[]
  transactions Transaction[]
  budgets      Budget[]

  @@map("users")
}

model Category {
  id           Int             @id @default(autoincrement())
  userId       Int             @map("user_id")
  name         String
  type         TransactionType
  color        String?
  createdAt    DateTime        @default(now()) @map("created_at")
  deletedAt    DateTime?       @map("deleted_at")

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@map("categories")
}

model Transaction {
  id           Int             @id @default(autoincrement())
  userId       Int             @map("user_id")
  categoryId   Int             @map("category_id")
  amount       Decimal         @db.Decimal(12, 2)
  type         TransactionType
  date         DateTime        @db.Date
  createdAt    DateTime        @default(now()) @map("created_at")
  deletedAt    DateTime?       @map("deleted_at") // Для Soft Delete


  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category        @relation(fields: [categoryId], references: [id])
  detail       TransactionDetail? // Связь 1-к-1 с деталями

  @@map("transactions")
}

model TransactionDetail {
  id            Int         @id @default(autoincrement())
  transactionId Int         @unique @map("transaction_id")
  description   String?     @db.Text

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("transaction_details")
}

model Budget {
  id           Int         @id @default(autoincrement())
  userId       Int         @map("user_id")
  categoryId   Int         @unique @map("category_id") // 1 лимит на 1 категорию пользователя
  amountLimit  Decimal     @map("amount_limit") @db.Decimal(12, 2)
  createdAt    DateTime    @default(now()) @map("created_at")

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("budgets")
}